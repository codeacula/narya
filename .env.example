PORT=4317
TWITCH_CHANNEL=codeacula

# OBS WebSocket defaults. Fill these in once OBS WebSocket is enabled.
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=

# Set to 0 to disable playerctl music polling.
MUSIC_POLL_INTERVAL_MS=2000

# Pin now playing to one playerctl player.
MUSIC_PLAYERCTL_PLAYER=strawberry

# Quack command playback volume from 0 to 1.
QUACK_VOLUME=0.20

# Twitch API + EventSub (stream uptime, follows, raids, subs, cheers, channel points).
# Use the dashboard Settings → "Login with Twitch" button to obtain a token at runtime.
# TWITCH_USER_TOKEN can be set manually as an alternative to the OAuth flow.
# TWITCH_BOT_USER_TOKEN can be set manually as an alternative to the bot OAuth flow.
# TWITCH_CLIENT_SECRET lets the backend use an app token for stream status before login.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_USER_TOKEN=
TWITCH_BOT_USER_TOKEN=
# Must match the redirect URI registered in your Twitch app.
# Use http://localhost:4317/api/auth/twitch/callback for Docker.
# Use http://localhost:5173/api/auth/twitch/callback for local dev via Vite.
TWITCH_REDIRECT_URI=http://localhost:5173/api/auth/twitch/callback

# Discord bot install + event-driven Twitch live announcements.
# Create a Discord application with a bot user, then use Settings -> Install Discord Bot.
# DISCORD_BOT_TOKEN is required on the backend to list servers/channels and post messages.
DISCORD_CLIENT_ID=
DISCORD_BOT_TOKEN=
# Must match a redirect URI registered in your Discord app.
# Use http://localhost:4317/api/auth/discord/callback for Docker.
# Use http://localhost:5173/api/auth/discord/callback for local dev via Vite.
DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/discord/callback

# Vite dev proxy targets (http://, not ws://, even for WebSocket)
VITE_BACKEND_ORIGIN=http://localhost:4317
VITE_BACKEND_WS_ORIGIN=http://localhost:4317
