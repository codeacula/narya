# =============================================================================
# Most configuration now lives in the app's Settings → "Connections & credentials"
# page and is stored in the database (data/streamer-tools.sqlite). You can hand the
# app to someone and have them configure Twitch, OBS, Discord, ElevenLabs, channel,
# music, and quack volume entirely from the UI — no .env editing required.
#
# The variables below are the only ones still read from the environment:
#   - PORT: the backend can't bind a port before the database is read, so it stays here.
#   - TWITCH_REDIRECT_URI / DISCORD_REDIRECT_URI: deploy-specific OAuth redirect URLs.
#   - VITE_*: build/dev-proxy targets, used at build time only.
#
# On first boot, any of the legacy variables in the "one-time migration" section are
# read ONCE to seed the database, so existing setups keep working. After that, edit
# values from the Settings UI — changes there override the .env seed.
# =============================================================================

PORT=4317

# OAuth redirect URIs — must match what's registered in your Twitch/Discord apps.
# Docker and local development both use Vite on port 5173.
TWITCH_REDIRECT_URI=http://localhost:5173/api/auth/twitch/callback
DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/discord/callback

# Vite dev proxy targets (http://, not ws://, even for WebSocket)
VITE_BACKEND_ORIGIN=http://localhost:4317
VITE_BACKEND_WS_ORIGIN=http://localhost:4317

# -----------------------------------------------------------------------------
# One-time migration only — read on first boot to seed the database, then ignored.
# Prefer configuring these from Settings → "Connections & credentials" instead.
# -----------------------------------------------------------------------------
# TWITCH_CHANNEL=codeacula
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
# OBS_WEBSOCKET_PASSWORD=
# OBS_SCENES=Coding,BRB,Starting Soon,Ending
# DISCORD_CLIENT_ID=
# DISCORD_BOT_TOKEN=
# ELEVENLABS_API_KEY=
# MUSIC_POLL_INTERVAL_MS=2000
# MUSIC_PLAYERCTL_PLAYER=strawberry
# QUACK_VOLUME=0.20

# Manual Twitch token fallbacks (alternative to the in-app OAuth login flow).
# TWITCH_USER_TOKEN=
# TWITCH_BOT_USER_TOKEN=
