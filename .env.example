# =============================================================================
# Narya reads almost nothing from the environment.
#
# Twitch, OBS, Discord, Tengwar, the channel, the OBS scene prefix, music, and
# sound volume all live in the database and are edited from Settings →
# "Connections & credentials". You can hand the app to someone and have them
# configure it entirely from the UI, and it boots fine with nothing configured.
#
# There is no .env seeding any more. Variables like TWITCH_CLIENT_ID, OBS_SCENES,
# and QUACK_VOLUME used to be read once on first boot to populate the database and
# then ignored forever — which made this file read like live configuration when it
# was nothing of the sort. They are gone. Set those values in Settings.
#
# What remains below is the set of values that genuinely cannot come from the
# database.
# =============================================================================

# The backend must bind a port before it can open the database, so this stays here.
PORT=4317

# Bind address for the backend and the Vite dev server. Loopback by default.
# Set HOST=0.0.0.0 to reach the tablet/overlays from other devices on your network
# — that REQUIRES DASHBOARD_TOKEN below, and the app refuses to start without it.
# HOST=0.0.0.0

# Operator token: full control over every /api/* route and the WebSocket. Present it
# via Authorization: Bearer, the x-dashboard-token header, or ?token=.
# Optional only while the app is bound to loopback (the default), where the OS is the
# boundary. Mandatory as soon as HOST exposes it beyond this machine.
#   DASHBOARD_TOKEN=$(openssl rand -hex 32)
# Open the app once as http://host:5173/?token=... (also /tablet) — the token is saved
# to localStorage and stripped from the URL.
#
# OBS browser sources use a separate READ-ONLY overlay token, derived from this one, so
# a URL sitting in a scene collection can't ban viewers or read your credentials. Get it
# from GET /api/auth/overlay-token (see README) and use it in the ?token= of /overlay URLs.
# DASHBOARD_TOKEN=

# OAuth redirect URIs. These cannot be derived from anything: they must match, character
# for character, what is registered in your Twitch/Discord developer console. The values
# shown are the built-in defaults and cover local dev through the Vite proxy — uncomment
# and edit only if you deploy differently.
# TWITCH_REDIRECT_URI=http://localhost:5173/api/auth/twitch/callback
# DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/discord/callback

# Vite dev proxy targets (http://, not ws://, even for WebSocket). Build-time only.
VITE_BACKEND_ORIGIN=http://localhost:4317
VITE_BACKEND_WS_ORIGIN=http://localhost:4317
