PORT=4317
TWITCH_CHANNEL=codeacula

# OBS WebSocket defaults. Fill these in once OBS WebSocket is enabled.
OBS_WEBSOCKET_URL=ws://127.0.0.1:4455
OBS_WEBSOCKET_PASSWORD=

# Set to 0 to disable playerctl music polling.
MUSIC_POLL_INTERVAL_MS=2000

# Pin now playing to one playerctl player.
MUSIC_PLAYERCTL_PLAYER=strawberry

# Quack command playback volume from 0 to 1.
QUACK_VOLUME=0.20

# Twitch EventSub (follows, raids, subs, cheers, channel points).
# You can set these in Dashboard → Settings → Connections and use "Login with Twitch" instead.
# Register your app at developer.twitch.tv and add redirect URI: http://localhost:4317/api/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_USER_TOKEN=

# Override the OAuth callback URL (only needed if running on a non-default port).
# TWITCH_REDIRECT_URI=http://localhost:4317/api/twitch/callback
